# tos-stats environment.
# Скопировать в .env на сервере и заполнить значениями.
# .env НИКОГДА не коммитится в git (см .gitignore).

# ----- Anthropic API (TOS AI narrative) -----
ANTHROPIC_API_KEY=sk-ant-...

# ----- Discord webhook (один канал #cot-weekly) -----
# Создаётся в настройках канала -> Integrations -> Webhooks -> New Webhook -> Copy URL.
DISCORD_WEBHOOK_WEEKLY=https://discord.com/api/webhooks/CHANNEL_ID/TOKEN

# ID Discord-роли которой пинговать на extreme positioning.
# Пусто если нет роли -- алерты будут публиковаться без пинга.
DISCORD_SWING_ROLE_ID=

# ----- Telegram alerts (ошибки pipeline в ЛС Daniil'у) -----
# Создаётся через @BotFather -> /newbot.
TG_ALERT_BOT_TOKEN=
TG_ALERT_CHAT_ID=

# Опционально: 1 -> также шлёт TG-уведомление при успешном проходе pipeline.
# Полезно первые 2-3 недели для дебага, потом отключить.
TG_NOTIFY_SUCCESS=

# ----- Storage -----
# Путь к SQLite БД (на Callisto живёт в общей папке tos_bots).
TOS_STATS_DB=/root/tos_bots/data/stats.db

# ----- Misc -----
# URL фронтенда для ссылок в Discord embed.
# После привязки домена -> https://stats.theotherside.trading
SITE_URL=https://crypt0punky.github.io/tos-stats/
